# ============================================
# Dawat Express — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# Database (SQLite - file path)
DATABASE_URL=file:./db/custom.db

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_STRING

# NextAuth URL (your domain, e.g. https://dawatexpress.com)
NEXTAUTH_URL=http://localhost:3000

# Admin Credentials
ADMIN_EMAIL=admin@dawatexpress.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Google OAuth (optional — for user Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=