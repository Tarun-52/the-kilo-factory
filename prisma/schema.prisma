generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Category {
  id          String  @id @default(cuid())
  name        String
  icon        String  @default("🍽️")
  description String?
  displayOrder Int    @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       Item[]
}

model Item {
  id              String        @id @default(cuid())
  categoryId      String
  name            String
  description     String?
  vegFlag         Boolean       @default(false)
  spiceLevel      Int           @default(0)
  photoUrl        String?
  isBestseller    Boolean       @default(false)
  isNew           Boolean       @default(false)
  isTodaysDeal    Boolean       @default(false)
  isBulkOnly      Boolean       @default(false)
  leadTimeHours   Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  category        Category      @relation(fields: [categoryId], references: [id])
  variants        ItemVariant[]
}

model ItemVariant {
  id           String     @id @default(cuid())
  itemId       String
  unit         String     @default("1kg")
  price        Float
  stockStatus  String     @default("in_stock")
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  item         Item       @relation(fields: [itemId], references: [id])
  orderItems   OrderItem[]
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String    @default("flat")
  value         Float
  minOrderValue Float     @default(0)
  validFrom     DateTime  @default(now())
  validTo       DateTime?
  usageLimit    Int       @default(0)
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  mobile        String?
  email         String?   @unique
  emailVerified DateTime?    // <-- ADDED THIS
  image         String?
  password      String?      // <-- ADDED THIS
  addresses     Address[]
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  line1     String
  line2     String?
  city      String
  pincode   String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  orders    Order[]
}

model Order {
  id                 String     @id @default(cuid())
  userId             String?
  addressId          String?
  status             String     @default("placed")
  subtotal           Float
  gst                Float      @default(0)
  packagingFee       Float      @default(0)
  deliveryFee        Float      @default(0)
  discount           Float      @default(0)
  total              Float
  paymentMethod      String     @default("cod")
  paymentStatus      String     @default("pending")
  porterRef          String?
  porterTrackingUrl  String?
  specialInstructions String?
  couponId           String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  user               User?      @relation(fields: [userId], references: [id])
  address            Address?   @relation(fields: [addressId], references: [id])
  coupon             Coupon?    @relation(fields: [couponId], references: [id])
  items              OrderItem[]
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  itemVariantId   String
  qty             Int      @default(1)
  priceAtOrder    Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  order           Order        @relation(fields: [orderId], references: [id])
  itemVariant     ItemVariant  @relation(fields: [itemVariantId], references: [id])
}

model DeliveryZone {
  id             String  @id @default(cuid())
  pincode        String
  city           String
  deliveryFee    Float   @default(0)
  isServiceable  Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("order_manager")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id               String  @id @default(cuid())
  key              String  @unique
  value            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}


